<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ApplePoint - Cadastro</title>
  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
      background-color: #F0F2F5; /* Fundo cinza claro */
      color: #333;
    }
    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 40px;
      background-color: #1A1A1A; /* Preto mais suave */
      color: white;
      flex-wrap: wrap;
    }
    header .logo {
      font-weight: bold;
      font-size: 22px;
      margin-right: 20px;
    }
    header nav {
        display: flex;
        flex-grow: 1;
        justify-content: center;
        flex-wrap: wrap;
    }
    header nav a {
      margin: 0 18px;
      text-decoration: none;
      color: white;
      font-weight: 500;
      font-size: 15px;
      transition: opacity 0.2s;
      white-space: nowrap;
    }
    header nav a:hover {
        opacity: 0.8;
    }
    header .header-icons {
      display: flex;
      gap: 20px;
      font-size: 22px;
      margin-left: 20px;
    }

    .container {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: calc(100vh - 120px); /* Ajuste de altura */
      padding: 60px 20px; /* Mais padding responsivo */
    }
    .signup-section {
      background-color: white;
      border-radius: 15px; /* Mais arredondado */
      padding: 50px; /* Mais padding */
      box-shadow: 0 8px 20px rgba(0,0,0,0.1); /* Sombra mais destacada */
      text-align: center;
      max-width: 500px; /* Largura máxima para o formulário */
      width: 100%; /* Ocupa a largura total disponível */
      box-sizing: border-box; /* Inclui padding na largura */
    }
    .signup-form {
      margin: 0 auto;
    }
    .signup-form h1 {
      font-size: 32px; /* Título maior */
      margin-bottom: 35px; /* Mais espaço abaixo do título */
      color: #333;
      font-weight: 700;
    }
    .signup-form label {
      display: block;
      text-align: left;
      margin-bottom: 8px; /* Mais espaço */
      font-weight: 500;
      color: #555;
      font-size: 15px;
    }
    .signup-form input {
      width: calc(100% - 28px); /* Ajuste para padding */
      padding: 14px; /* Mais padding */
      margin: 10px 0 20px; /* Mais espaço */
      border: 1px solid #ddd; /* Borda mais clara */
      border-radius: 10px; /* Mais arredondado */
      font-size: 16px;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .signup-form input:focus {
      border-color: #007AFF;
      box-shadow: 0 0 0 3px rgba(0,122,255,0.2);
    }
    .signup-form button {
      width: 100%;
      padding: 16px; /* Mais padding */
      margin-top: 30px; /* Mais espaço */
      background-color: #007AFF;
      border: none;
      color: white;
      font-weight: bold;
      border-radius: 10px; /* Más arredondado */
      cursor: pointer;
      font-size: 18px;
      transition: background-color 0.2s, transform 0.1s;
    }
    .signup-form button:hover {
      background-color: #0056b3;
      transform: translateY(-2px);
    }
    .signup-form p {
      font-size: 15px;
      margin-top: 25px;
      color: #666;
    }
    .signup-form p a {
      text-decoration: none;
      color: #007AFF;
      font-weight: bold;
      transition: opacity 0.2s;
    }
    .signup-form p a:hover {
        opacity: 0.8;
    }
    .signup-form .social-login {
        margin-top: 25px;
    }
    .signup-form .social-login button {
        background-color: #f0f0f0; /* Fundo mais claro */
        color: #555; /* Texto mais escuro */
        border: 1px solid #ccc;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px; /* Mais espaço */
        font-size: 17px;
        padding: 14px; /* Mais padding */
        border-radius: 10px;
        transition: background-color 0.2s;
    }
    .signup-form .social-login button:hover {
        background-color: #e0e0e0;
    }
    .signup-form .social-login button img {
        width: 26px; /* Ícone maior */
        height: 26px;
    }
    .separator {
        text-align: center;
        margin: 30px 0; /* Mais espaço */
        color: #aaa;
        position: relative;
        font-size: 15px;
    }
    .separator::before, .separator::after {
        content: '';
        position: absolute;
        top: 50%;
        width: 38%; /* Largura ajustada */
        height: 1px;
        background-color: #eee;
    }
    .separator::before {
        left: 0;
    }
    .separator::after {
        right: 0;
    }

    footer {
      background: #1A1A1A; /* Preto mais suave */
      color: white;
      padding: 50px 40px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 50px;
      margin-top: 80px;
    }
    footer h3 {
      color: white;
      margin-bottom: 20px;
      font-size: 20px;
      font-weight: 600;
    }
    footer p, footer a {
      color: #ccc;
      line-height: 1.8;
      font-size: 15px;
      text-decoration: none;
    }
    footer a:hover {
        text-decoration: underline;
    }
    footer input, footer textarea {
      width: calc(100% - 28px);
      padding: 14px;
      margin-top: 12px;
      border-radius: 8px;
      border: none;
      background-color: #2A2A2A;
      color: white;
      font-size: 15px;
    }
    footer textarea {
      min-height: 100px;
      resize: vertical;
    }
    footer button {
      margin-top: 18px;
      padding: 14px 25px;
      background-color: #007AFF;
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
      font-size: 16px;
      transition: background-color 0.2s;
    }
    footer button:hover {
      background-color: #0056b3;
    }
    .social-icons a img {
      width: 35px;
      margin-right: 20px;
      vertical-align: middle;
      filter: invert(100%);
    }
    .copyright {
      text-align: center;
      color: #ccc;
      font-size: 13px;
      padding-top: 25px;
      border-top: 1px solid #3A3A3A;
      margin-top: 40px;
      grid-column: 1 / -1;
    }

    /* --- Responsividade --- */
    @media (max-width: 768px) {
        header {
            flex-direction: column;
            padding: 15px 20px;
        }
        header .logo {
            margin-bottom: 10px;
        }
        header nav {
            width: 100%;
            margin-bottom: 15px;
        }
        header nav a {
            margin: 5px 10px;
            font-size: 14px;
        }
        header .header-icons {
            margin-left: 0;
            margin-top: 10px;
            font-size: 20px;
        }

        .container {
            padding: 40px 20px;
        }
        .signup-section {
            padding: 40px 30px;
        }
        .signup-form h1 {
            font-size: 28px;
            margin-bottom: 30px;
        }
        .signup-form label {
            font-size: 14px;
        }
        .signup-form input {
            padding: 12px;
            font-size: 15px;
        }
        .signup-form button {
            padding: 14px;
            font-size: 16px;
        }
        .signup-form p {
            font-size: 14px;
        }
        .signup-form .social-login button {
            font-size: 15px;
            padding: 12px;
        }
        .signup-form .social-login button img {
            width: 24px;
            height: 24px;
        }
        .separator {
            margin: 25px 0;
            font-size: 14px;
        }
        .separator::before, .separator::after {
            width: 35%;
        }

        footer {
            grid-template-columns: 1fr;
            padding: 40px 20px;
            gap: 30px;
        }
        footer h3 {
            font-size: 18px;
            margin-bottom: 15px;
        }
        footer p, footer a, footer input, footer textarea {
            font-size: 14px;
        }
        footer input, footer textarea {
            width: calc(100% - 20px);
            padding: 10px;
        }
        footer button {
            padding: 12px;
            font-size: 15px;
        }
        .social-icons a img {
            width: 30px;
            margin-right: 15px;
        }
        .copyright {
            font-size: 11px;
            padding-top: 20px;
            margin-top: 30px;
        }
    }

    @media (max-width: 480px) {
        .signup-section {
            padding: 30px 20px;
        }
        .signup-form h1 {
            font-size: 26px;
        }
    }
  </style>
</head>
<body>

  <header>
    <div class="logo"><strong>ApplePoint</strong></div>
    <nav>
      <a href="inicial.html">Página Inicial</a>
      <a href="products-list.html">Produtos</a>
      <a href="contact.html">Contato</a>
      <a href="dashboard.html">Minha Conta</a>
      <a href="login.html">Login</a>
    </nav>
    <div class="header-icons">🛒 ❤️ 👤</div>
  </header>

  <main class="container">
    <div class="signup-section">
      <div class="signup-form">
        <h1>Cadastro</h1>
        <form onsubmit="return criarConta()">
          <label for="usuario">Usuário</label>
          <input type="text" id="usuario" name="usuario" placeholder="Lucas Neto" required>
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="exemplo@email.com" required>
          <label for="senha">Senha</label>
          <input type="password" id="senha" name="senha" placeholder="Digite sua Senha" required>
          <label for="confirma-senha">Confirme sua Senha</label>
          <input type="password" id="confirma-senha" name="confirma" placeholder="Digite sua Senha" required>
          <label for="telefone">Número de Telefone</label>
          <input type="tel" id="telefone" name="telefone" placeholder="Enter your phone number" required>
          <button type="submit">Criar conta</button>
          <p>
            Já tem conta? <a href="login.html">Logue Agora</a>
          </p>
          <div class="separator">OU</div>
          <div class="social-login">
            <button type="button">
              <img src="https://img.icons8.com/color/48/000000/google-logo.png" alt="Google">
              Continue com o Google
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>

  <footer>
    <div class="footer-column">
      <h3>SUPORTE</h3>
      <p>Está com dúvida? Envie uma mensagem para o nosso time de suporte</p>
      <form onsubmit="enviarMensagem(event)">
        <input type="email" name="email" placeholder="E-mail de contato" required>
        <textarea name="mensagem" placeholder="Mensagem" required></textarea>
        <button type="submit">Enviar</button>
      </form>
    </div>

    <div class="footer-column">
      <h3>Empresa</h3>
      <a href="#">Produtos</a>
      <a href="#">Serviços</a>
      <a href="#">FAQ</a>
    </div>

    <div class="footer-column">
      <h3>Entre em Contato</h3>
      <p>+55 47 9 9280-5090</p>
      <p>help@ApplePoint.com.br</p>
      <p>São Paulo - SP</p>
      <div class="social-icons">
        <a href="https://www.facebook.com/apple" target="_blank">
          <img src="https://cdn-icons-png.flaticon.com/512/733/733547.png" alt="Facebook">
        </a>
        <a href="https://www.instagram.com/apple" target="_blank">
          <img src="https://cdn-icons-png.flaticon.com/512/733/733558.png" alt="Instagram">
        </a>
        <a href="https://www.youtube.com/apple" target="_blank">
          <img src="https://cdn-icons-png.flaticon.com/512/1384/1384060.png" alt="YouTube">
        </a>
      </div>
    </div>
    <div class="copyright">
      <p>2025-ApplePoint</p>
    </div>
  </footer>

<script>
    function criarConta() {
      window.location.href = "login.html";
      return false;
    }

    function enviarMensagem(event) {
      if (event) {
        event.preventDefault();
      }
      alert("Mensagem enviada com sucesso!");
    }
</script>
</body>
</html>
